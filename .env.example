# ─────────────────────────────────────────────────────────
# SEO Content Automation Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════
# REQUIRED: Your Gemini API Key (at least one is needed)
# ═══════════════════════════════════════════════════════

# Option A: Single API key
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Multiple keys for rotation (comma-separated)
# GEMINI_API_KEYS=key1,key2,key3,key4

# ═══════════════════════════════════════════════════════
# OPTIONAL: Pipeline Configuration
# ═══════════════════════════════════════════════════════

# Target a specific high-CPC niche:
#   cloud_computing       → $15-$40 CPC
#   cybersecurity         → $20-$50 CPC
#   enterprise_software   → $10-$30 CPC
#   managed_it_services   → $25-$60+ CPC
# Leave empty for random niche selection each run.
# TARGET_NICHE=cybersecurity

# Or provide a custom keyword to search for:
# CUSTOM_KEYWORD=Kubernetes pod CrashLoopBackOff fix

# Or provide direct source URLs (comma-separated) — skips DuckDuckGo search:
# SOURCE_URLS=https://stackoverflow.com/questions/12345,https://techcommunity.microsoft.com/...
